# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...    # SERVER ONLY — never expose to frontend

# ── AI Model paths ────────────────────────────────────────────────────────────
TUMOR_MODEL_PATH=./models/brain_tumor_model.h5
STROKE_MODEL_PATH=./models/stroke_model.h5

# ── CORS ──────────────────────────────────────────────────────────────────────
# Production: your Vercel URL. Dev: http://localhost:5173
ALLOWED_ORIGIN=https://your-app.vercel.app

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development              # development | production
LOG_LEVEL=INFO

# ── Rate limiting ─────────────────────────────────────────────────────────────
PREDICT_RATE_LIMIT=10/minute     # per user JWT
